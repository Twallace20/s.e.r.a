{
  "name": "s-e-r-a",
  "version": "0.1.0",
  "private": true,
  "description": "S.E.R.A. clean-core: secure local runtime, evidence artifacts, modular agent foundation.",
  "type": "commonjs",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "node scripts/clean.mjs",
    "hygiene": "npm run hygiene:source && npm run hygiene:runtime",
    "hygiene:source": "node scripts/check-source-hygiene.mjs",
    "hygiene:runtime": "node scripts/check-runtime-artifacts.mjs",
    "test": "vitest run",
    "certify": "npm run build && npm test && node packages/certs/dist/certify.js",
    "sera": "npm run build --silent && node apps/cli/dist/index.js",
    "doctor": "node scripts/doctor.mjs",
    "knowledge:seed": "npm run build --silent && node scripts/seed-local-knowledge.mjs --reset",
    "knowledge:source-map": "node scripts/check-knowledge-source-map.mjs",
    "knowledge:verify": "npm run knowledge:source-map",
    "verify": "npm run hygiene && npm run knowledge:verify && npm run build && npm test && npm run certify",
    "ci": "npm run verify"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
