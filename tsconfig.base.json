{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": [
      "ES2022"
    ],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@sera/shared": [
        "packages/shared/src/index.ts"
      ],
      "@sera/safety": [
        "packages/safety/src/index.ts"
      ],
      "@sera/artifacts": [
        "packages/artifacts/src/index.ts"
      ],
      "@sera/workspace": [
        "packages/workspace/src/index.ts"
      ],
      "@sera/tools": [
        "packages/tools/src/index.ts"
      ],
      "@sera/kernel": [
        "packages/kernel/src/index.ts"
      ],
      "@sera/certs": [
        "packages/certs/src/index.ts"
      ],
      "@sera/planner": [
        "packages/planner/src/index.ts"
      ],
      "@sera/memory": [
        "packages/memory/src/index.ts"
      ],
      "@sera/workers": [
        "packages/workers/src/index.ts"
      ],
      "@sera/self-improvement": [
        "packages/self-improvement/src/index.ts"
      ],
      "@sera/knowledge": [
        "packages/knowledge/src/index.ts"
      ],
      "@sera/model-provider": [
        "packages/model-provider/src/index.ts"
      ],
      "@sera/autonomy": [
        "packages/autonomy/src/index.ts"
      ],
      "@sera/operator-console": [
        "packages/operator-console/src/index.ts"
      ]
    }
  }
}
